generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  DRAFT
  SUBMITTED
  ARCHIVED
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}

model FormTemplate {
  id          String   @id @default(cuid())
  systemKey   String?  @unique @map("system_key")
  name        String
  description String?
  category    String?
  fields      Json     @default("[]")
  isDefault   Boolean  @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  jobs Job[]

  @@map("form_templates")
}

model Job {
  id          String    @id @default(cuid())
  name        String?
  jobNumber   String?   @map("job_number")
  status      JobStatus @default(DRAFT)
  submittedBy      String?   @map("submitted_by")
  submittedAt      DateTime? @map("submitted_at") @db.Timestamptz(6)
  workerSignature  String?   @map("worker_signature")
  // Pessimistic durable flag for "job marked SUBMITTED but office email
  // didn't go through." Set true inside the same atomic write that flips
  // status → SUBMITTED, then cleared to false only after a confirmed
  // Resend success. If anything in the post-send path fails, the flag
  // stays true so the UI over-warns rather than falsely claiming success.
  // null = legacy rows / no attempt yet.
  lastEmailFailed  Boolean?  @map("last_email_failed")

  photos   Json  @default("[]")
  formData Json? @map("form_data")

  templateId String?       @map("template_id")
  template   FormTemplate? @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("jobs")
  @@index([status, createdAt(sort: Desc)])
}
